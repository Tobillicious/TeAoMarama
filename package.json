{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "gemini-react-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://admin.github.io/gemini-react-app",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsx scripts/build-resources.ts && vite build",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "build:analyze": "tsx scripts/build-resources.ts && vite build --mode analyze",
    "overseer:sync": "tsx scripts/overseer-sync.ts",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ci": "playwright test --reporter=line",
    "test:llm-performance": "tsx scripts/test-llm-performance.ts",
    "mihara": "tsx migration/simple-mihara.ts",
    "mihara:assist": "tsx migration/mihara-assistant.ts",
    "fix:typescript": "tsx scripts/targeted-fix.ts",
    "doctor": "tsx migration/connection-diagnostic.ts",
    "agents": "tsx migration/run-agents.ts",
    "mig:pg:run": "tsx migration/pgvector_loader_example.ts --sample migration/sample_raw_exports.jsonl",
    "mig:pg:run:file": "ts-node migration/pgvector_loader_example.ts --sample",
    "mig:weaviate:run": "tsx migration/weaviate_loader_example.ts --sample migration/sample_raw_exports.jsonl",
    "typecheck": "tsc -b --pretty",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "agents:coord": "tsx migration/agent-coordinator.ts",
    "agents:support": "tsx continuous-mihara-support.ts",
    "agents:background": "tsx migration/agent-background.ts",
    "agents:bus": "tsx migration/agent-terminal-bus.ts",
    "deploy:netlify": "netlify deploy --dir=dist --prod",
    "build:deploy": "npm run build && npm run deploy:netlify",
    "test:e2e:ui": "playwright test --ui",
    "workflow:check": "node scripts/simple-workflow-check.cjs",
    "monitor:runtime": "tsx scripts/runtime-monitoring.ts",
    "monitor:performance": "tsx scripts/performance-monitoring.ts",
    "deploy:firebase": "npm run build && firebase deploy",
    "import:te-kete": "tsx migration/import-te-kete-ako.ts --source /Users/admin/Documents/te-kete-ako-clean",
    "gen:resources": "tsx scripts/generate-bulk-resources.ts --count 1000 && tsx scripts/build-resources.ts",
    "gen:resources:2000": "tsx scripts/generate-bulk-resources.ts --count 2000 && tsx scripts/build-resources.ts",
    "heartbeat": "tsx scripts/agent-heartbeat.ts",
    "heartbeat:overseer": "AGENT_NAME=agent:windsurf-overseer CHAIN_ID=overseer-heartbeat INTERVAL_MS=180000 tsx scripts/agent-heartbeat.ts",
    "heartbeat:mihara": "AGENT_NAME=agent:kaitiaki-mahara CHAIN_ID=mihara-heartbeat INTERVAL_MS=300000 tsx scripts/agent-heartbeat.ts",
    "assist:loop": "nohup sh -c 'while true; do npx tsx mihara-assistant.ts >> /tmp/mihara_assist.log 2>&1; sleep 300; done' >/dev/null 2>&1 &",
    "heartbeat:daemon": "nohup npm run heartbeat:overseer >/dev/null 2>&1 &",
    "mahara:awaken": "npx tsx mihara-continuous-assistant.ts",
    "mahara:monitor": "npx tsx continuous-mihara-support.ts",
    "workflow:optimize": "npx tsx mahara-instant-workflow.ts",
    "agent:heartbeat": "npx tsx scripts/agent-heartbeat.ts",
    "performance:audit": "npx lighthouse http://localhost:5174 --output=json --output-path=./lighthouse-audit.json --chrome-flags=\"--headless\"",
    "performance:report": "npm run performance:audit && node -e \"const report = require('./lighthouse-audit.json'); console.log('Performance Score:', report.categories.performance.score); console.log('LCP:', report.audits['largest-contentful-paint'].displayValue); console.log('FCP:', report.audits['first-contentful-paint'].displayValue);\"",
    "glm:enhance": "tsx scripts/glm-batch-enhancement.ts",
    "glm:test": "tsx -e \"console.log('GLM integration test - use GLM_API_KEY=your_key npm run glm:enhance')\"",
    "glm:process": "tsx scripts/glm-enhancement-manager.ts process",
    "glm:status": "tsx scripts/glm-enhancement-manager.ts status",
    "glm:enhance-content": "tsx scripts/glm-enhancement-manager.ts enhance",
    "glm:symphony:orchestrate": "tsx scripts/glm-symphony-orchestrator.ts orchestrate",
    "glm:symphony:status": "tsx scripts/glm-symphony-orchestrator.ts status",
    "glm:symphony:enhance": "tsx scripts/glm-symphony-orchestrator.ts enhance",
    "glm:generate": "tsx scripts/glm-content-generator.ts generate",
    "glm:report": "tsx scripts/glm-content-generator.ts report",
    "glm:list": "tsx scripts/glm-content-generator.ts list",
    "glm:test:run": "tsx scripts/glm-ecosystem-test.ts run",
    "glm:test:quick": "tsx scripts/glm-ecosystem-test.ts quick",
    "glm:workflow:run": "tsx scripts/glm-workflow-automation.ts run",
    "exa:update-links": "tsx scripts/update-resource-links.ts",
    "exa:validate-url": "tsx -e \"import { exaLinkValidator } from './src/utils/exa-link-validator.ts'; console.log('Exa Link Validator ready');\"",
    "polish:test": "tsx scripts/comprehensive-polish-test.ts",
    "glm:workflow:status": "tsx scripts/glm-workflow-automation.ts status",
    "glm:workflow:list": "tsx scripts/glm-workflow-automation.ts list",
    "glm:workflow:report": "tsx scripts/glm-workflow-automation.ts report",
    "wisdom:start": "tsx scripts/wisdom-evolution-superconsciousness.ts",
    "wisdom:status": "tsx scripts/wisdom-controller.ts status",
    "wisdom:silent": "tsx scripts/wisdom-controller.ts silent",
    "wisdom:stop": "tsx scripts/wisdom-controller.ts stop"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-tabs": "^1.1.13",
    "@supabase/supabase-js": "^2.55.0",
    "@tanstack/react-virtual": "^3.13.12",
    "@types/marked": "^5.0.2",
    "@types/sanitize-html": "^2.16.0",
    "axios": "^1.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exa-js": "^1.9.3",
    "firebase": "^12.1.0",
    "firebase-admin": "^13.4.0",
    "framer-motion": "^12.23.12",
    "glob": "^11.0.3",
    "jsdom": "^26.1.0",
    "lucide-react": "^0.539.0",
    "marked": "^16.1.2",
    "pg": "^8.16.3",
    "puppeteer": "^24.16.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.8.0",
    "react-window": "^1.8.11",
    "recharts": "^3.1.2",
    "sanitize-html": "^2.17.0",
    "tailwind-merge": "^3.3.1",
    "weaviate-client": "^3.8.0",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4.1.11",
    "@testing-library/jest-dom": "^6.8.0",
    "@types/node": "^24.2.1",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.21",
    "compression-webpack-plugin": "^11.1.0",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "gh-pages": "^6.3.0",
    "globals": "^16.3.0",
    "lighthouse": "^12.8.2",
    "playwright": "^1.55.0",
    "postcss": "^8.5.6",
    "rollup-plugin-visualizer": "^6.0.3",
    "tailwindcss": "^4.1.11",
    "terser": "^5.43.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.4",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.0",
    "vite": "^7.1.0",
    "vite-plugin-compression2": "^2.2.0",
    "vitest": "^3.2.4",
    "webpack-bundle-analyzer": "^4.10.2"
  }
}
