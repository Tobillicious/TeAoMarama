# Firebase Configuration for Te Ao Mārama - Educational Resources Platform
# Copy this file to .env.local and fill in your Firebase values
# Get these values from your Firebase project console: https://console.firebase.google.com/

# Required Firebase Configuration
# Vite exposes vars prefixed with VITE_ to the client
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Optional Firebase Configuration
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id_for_analytics
VITE_FIREBASE_DATABASE_URL=https://your_project_id-default-rtdb.firebaseio.com/

# Firebase Development & Testing Configuration
VITE_ENABLE_SUPABASE=false
VITE_USE_FIREBASE_EMULATOR=false
VITE_FIREBASE_EMULATOR_AUTH_PORT=9099
# Uncomment these lines if you want to use Firebase emulators in development
# VITE_FIREBASE_AUTH_EMULATOR_URL=http://localhost:9099
# VITE_FIRESTORE_EMULATOR_HOST=localhost:8080
# VITE_FUNCTIONS_EMULATOR_HOST=localhost:5001

# Application Configuration
VITE_APP_NAME="Te Ao Mārama - Educational Resources"
VITE_APP_DESCRIPTION="Culturally responsive educational platform for Aotearoa New Zealand"

# Cultural Context Configuration for Māori Integration
VITE_DEFAULT_LANGUAGE=both
VITE_CULTURAL_SENSITIVITY_LEVEL=medium
VITE_ENABLE_MAORI_LANGUAGE=true
VITE_CULTURAL_VALIDATION_ENABLED=true

# ERO Demonstration Mode
VITE_ERO_DEMO_MODE=false
VITE_ERO_SCHOOL_NAME="Mangakōtukutuku College"
VITE_ERO_DEMO_USERS=teacher@demo.school.nz,student@demo.school.nz

# Performance and Monitoring
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_PERFORMANCE_MONITORING=true
VITE_LOG_LEVEL=info

# Authentication Security Configuration
VITE_ENABLE_OFFLINE_PERSISTENCE=true
VITE_SESSION_TIMEOUT_MINUTES=30
VITE_MAX_LOGIN_ATTEMPTS=5
VITE_REQUIRE_EMAIL_VERIFICATION=true

# Development Configuration
VITE_DEV_SHOW_FIREBASE_STATUS=true
VITE_DEV_ENABLE_DEBUG_LOGS=true
VITE_DEV_MOCK_AUTH=false

# Security Headers (Production)
VITE_CSP_ENABLED=true
VITE_HSTS_ENABLED=true

# Server-side only (do not expose to client)
# Used by migration loaders (weaviate/pgvector). Keep these out of git.
FIREBASE_SERVICE_ACCOUNT_JSON_PATH=
FIREBASE_PROJECT_ID=teao-marama
MIGRATION_ENV=staging

# Exa.ai API for kupu crawling
EXA_API_KEY=

# Postgres / pgvector
PG_URL=
PGVECTOR_DIM=1536
PGVECTOR_TABLE_RESOURCE_CHUNKS=resource_chunks

# Embeddings
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=

# Supabase (used by Te Kete Ako client)
VITE_TEKETE_SUPABASE_URL=
VITE_TEKETE_SUPABASE_ANON_KEY=
