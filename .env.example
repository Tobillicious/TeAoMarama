# Copy this file to .env.local and fill in your Firebase values
# Vite exposes vars prefixed with VITE_
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Server-side only (do not expose to client)
# Used by migration loaders (weaviate/pgvector). Keep these out of git.
FIREBASE_SERVICE_ACCOUNT_JSON_PATH=
FIREBASE_PROJECT_ID=teao-marama
MIGRATION_ENV=staging

# Postgres / pgvector
PG_URL=
PGVECTOR_DIM=1536
PGVECTOR_TABLE_RESOURCE_CHUNKS=resource_chunks

# Embeddings
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
