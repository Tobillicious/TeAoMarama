rules_version = '2';
// Firebase Security Rules for Te Ao Mārama - Educational Resources Platform
// Comprehensive security rules supporting teacher/student/admin roles with cultural sensitivity
service cloud.firestore {
  match /databases/{database}/documents {

    // Utility functions for role-based access control
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }
    
    function isAdmin() {
      return hasRole('admin') || (isAuthenticated() && request.auth.token.admin == true);
    }
    
    function isTeacher() {
      return hasRole('teacher') || hasRole('admin');
    }
    
    function isStudent() {
      return hasRole('student');
    }
    
    function isKaitiaki() {
      return hasRole('kaitiaki') || hasRole('admin');
    }
    
    function canAccessCulturalContent(sensitivityLevel) {
      // Admin, teachers, and kaitiaki can access all levels
      return isAdmin() || isTeacher() || isKaitiaki() || 
        // Students can access low and medium sensitivity content
        (isStudent() && sensitivityLevel in ['low', 'medium']);
    }
    
    function isSchoolMember() {
      return isAuthenticated() && getUserData().school != null;
    }

    // User profiles - users can read/update their own, teachers can read students in their school
    match /users/{userId} {
      allow read: if isOwner(userId) || 
                     (isTeacher() && get(/databases/$(database)/documents/users/$(userId)).data.school == getUserData().school) ||
                     isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) ||
                       (isTeacher() && get(/databases/$(database)/documents/users/$(userId)).data.role == 'student') ||
                       isAdmin();
      allow delete: if isAdmin();
    }

    // Public educational resources - tiered access based on cultural sensitivity
    match /resources/{resourceId} {
      allow read: if true; // Base read access for all
      allow create: if isTeacher() || isAdmin();
      allow update: if isTeacher() || isAdmin() || 
                       (isAuthenticated() && resource.data.createdBy == request.auth.uid);
      allow delete: if isAdmin() || 
                       (isTeacher() && resource.data.createdBy == request.auth.uid);
    }
    
    // Cultural content with enhanced protection
    match /cultural_content/{contentId} {
      allow read: if isAuthenticated() && 
                     canAccessCulturalContent(resource.data.sensitivityLevel);
      allow create: if isTeacher() || isAdmin();
      allow update: if isAdmin() || 
                       (isTeacher() && resource.data.approvedByKaitiaki == true);
      allow delete: if isAdmin();
    }

    // User-generated content (assignments, projects, submissions)
    match /user_content/{userId}/submissions/{submissionId} {
      allow read, write: if isOwner(userId) || 
                            (isTeacher() && get(/databases/$(database)/documents/users/$(userId)).data.school == getUserData().school) ||
                            isAdmin();
    }

    // Classroom/school-specific collections
    match /schools/{schoolId}/classrooms/{classroomId} {
      allow read: if isAuthenticated() && 
                     (getUserData().school == schoolId || isAdmin());
      allow write: if isTeacher() && getUserData().school == schoolId || isAdmin();
      
      // Student work within classrooms
      match /student_work/{studentId} {
        allow read, write: if isOwner(studentId) || 
                              (isTeacher() && getUserData().school == schoolId) ||
                              isAdmin();
      }
    }

    // Learning analytics - privacy-protected student data
    match /analytics/{userId} {
      allow read: if isOwner(userId) || 
                     (isTeacher() && get(/databases/$(database)/documents/users/$(userId)).data.school == getUserData().school && 
                      get(/databases/$(database)/documents/users/$(userId)).data.role == 'student') ||
                     isAdmin();
      allow write: if isOwner(userId) || isTeacher() || isAdmin();
    }

    // Teacher resources and planning
    match /teacher_resources/{resourceId} {
      allow read: if isTeacher() || isAdmin();
      allow create, update: if isTeacher() || isAdmin();
      allow delete: if isAdmin() || 
                       (isTeacher() && resource.data.createdBy == request.auth.uid);
    }

    // Admin-only collections
    match /imports/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /reviews/{docId} {
      allow read, write: if isAdmin();
    }
    
    match /system_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated(); // Users can create their own activity logs
    }

    // ERO demonstration data - special read access
    match /ero_demo/{demoId} {
      allow read: if true; // Public for ERO presentations
      allow write: if isAdmin();
    }

    // Assessment and rubric data
    match /assessments/{assessmentId} {
      allow read: if isAuthenticated();
      allow create, update: if isTeacher() || isAdmin();
      allow delete: if isAdmin();
    }

    // Feedback and comments
    match /feedback/{feedbackId} {
      allow read: if isAuthenticated() && 
                     (resource.data.studentId == request.auth.uid || 
                      resource.data.teacherId == request.auth.uid ||
                      isAdmin());
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() || resource.data.authorId == request.auth.uid;
    }

    // Notification system
    match /notifications/{userId} {
      allow read, write: if isOwner(userId);
      allow create: if isTeacher() || isAdmin(); // Teachers and admins can send notifications
    }

    // Cultural consultation tracking
    match /cultural_reviews/{reviewId} {
      allow read: if isTeacher() || isAdmin();
      allow create, update: if isAdmin() || 
                               (isAuthenticated() && getUserData().culturalReviewer == true);
    }

    // Parent/whānau access (limited)
    match /student_progress/{studentId} {
      allow read: if isOwner(studentId) || 
                     (isAuthenticated() && resource.data.parentAccess != null && 
                      request.auth.uid in resource.data.parentAccess) ||
                     (isTeacher() && get(/databases/$(database)/documents/users/$(studentId)).data.school == getUserData().school) ||
                     isAdmin();
    }

    // Performance and monitoring data
    match /performance_metrics/{metricId} {
      allow read: if isTeacher() || isAdmin();
      allow write: if isAdmin();
    }

    // Default security - deny all access to unlisted collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
