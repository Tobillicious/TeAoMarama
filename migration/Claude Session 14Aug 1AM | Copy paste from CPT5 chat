dotenv.config();

const PORT = process.env.PORT ? parseInt(process.env.PORT) : 3000;
const LLM_PROVIDER = (process.env.LLM_PROVIDER || 'generic').toLowerCase(); // 'generic' or 'anthropic'
const LLM_API_KEY = process.env.LLM_API_KEY || '';
const LLM_API_URL = process.env.LLM_API_URL || ''; // required for generic, recommended for anthropic
const LLM_MODEL = process.env.LLM_MODEL || 'claude-2.1';

if (!LLM_API_KEY) {
  console.warn('Warning: LLM_API_KEY is not set. Endpoint will fail when calling the LLM.');
