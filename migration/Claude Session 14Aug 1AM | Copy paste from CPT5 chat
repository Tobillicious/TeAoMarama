// src/ai/providers/deepseek.ts
import { LLM, GenOpts, GenResult } from "../types";

const BASE = process.env.DEEPSEEK_BASE_URL || "https://api.deepseek.com";
const KEY  = process.env.DEEPSEEK_API_KEY!;

async function httpJson(url: string, body: any, headers: Record<string,string> = {}) {
  const t0 = Date.now();
  const res = await fetch(url, {
    method: "POST",
    headers: { "Authorization": `Bearer ${KEY}`, "Content-Type": "application/json", ...headers },
    body: JSON.stringify(body)
  });
  const t1 = Date.now();
  if (!res.ok) throw new Error(`DeepSeek HTTP ${res.status}: ${await res.text()}`);
  const json = await res.json();
  return { json, latencyMs: t1 - t0 };
}

export class DeepSeek implements LLM {
  name = "deepseek";

  async generate(prompt: string, opts: GenOpts): Promise<GenResult> {
    const model = opts.model || "deepseek-chat";
    const system = opts.system || "You are a helpful assistant.";
    const jsonMode = !!opts.json;

    // Minimal OpenAI-like shape; adapt if your SDK differs
    const { json, latencyMs } = await httpJson(`${BASE}/v1/chat/completions`, {
      model,
      response_format: jsonMode ? { type: "json_object" } : undefined,
      temperature: opts.temperature ?? 0.2,
      max_tokens: opts.maxTokens ?? 800,
      stop: opts.stop,
      messages: [
        { role: "system", content: system },
        { role: "user", content: prompt }
      ]
    });

    const choice = json.choices?.[0];
    const text = choice?.message?.content ?? "";
    const usage = json.usage ?? { prompt_tokens: 0, completion_tokens: 0 };

    return {
      output: text,
      tokensIn: usage.prompt_tokens || 0,
      tokensOut: usage.completion_tokens || 0,
      latencyMs,
      provider: this.name,
      model,
      raw: json
    };
  }

  // Optional embeddings (if available on your account)
  async embed(texts: string[], model = "deepseek-embed") {
    const { json } = await httpJson(`${BASE}/v1/embeddings`, { model, input: texts });
    return { vectors: json.data.map((d: any) => d.embedding), model };
  }
}
