// src/ingest/ingest.ts
import fs from 'fs';
import pdfParse from 'pdf-parse';
import axios from 'axios';
import { createClient } from '@supabase/supabase-js';
import dotenv from 'dotenv';
import { v4 as uuidv4 } from 'uuid';
dotenv.config();

const SUPABASE_URL = process.env.SUPABASE_URL!;
const SUPABASE_KEY = process.env.SUPABASE_SERVICE_KEY!;
const EXTRACTOR_URL = process.env.EXTRACTOR_URL || 'http://localhost:3001/extract';
const OPENAI_API_KEY = process.env.OPENAI_API_KEY || '';
const EMBED_DIM = Number(process.env.EMBED_DIM || 1536);
const supabase = createClient(SUPABASE_URL, SUPABASE_KEY);

async function embedText(text: string){
  if(!OPENAI_API_KEY) return Array.from({length: EMBED_DIM}, ()=>Math.random());
  const resp = await axios.post('https://api.openai.com/v1/embeddings', { model:'text-embedding-3-large', input: text }, { headers: { Authorization:`Bearer ${OPENAI_API_KEY}` }});
  return resp.data.data[0].embedding;
}

async function extractText(buf: Buffer){
  const d = await pdfParse(buf);
  return d.text || '';
}

function chunkText(text: string, max=3000){
  const out: string[] = [];
  let pos=0;
  while(pos < text.length){
    const slice = text.slice(pos, pos+max);
    const last = slice.lastIndexOf('\n\n');
    const take = last > 200 ? last : slice.length;
    out.push(slice.slice(0, take));
    pos += take;
  }
  return out;
}

export async function ingestPdf(filePath: string, meta: { title?: string, sourceUrl?: string } = {}) {
  const buf = fs.readFileSync(filePath);
  const text = await extractText(buf);
  const chunks = chunkText(text, 3000);

  const jobId = uuidv4();
  await supabase.from('agent_jobs').insert({ id: jobId, agent_name:'ingest_service', job_type:'ingest', input:{filePath, meta}, status:'running', created_at:new Date().toISOString() });

  try {
    for(const chunk of chunks){
      const resp = await axios.post(EXTRACTOR_URL, { chunkText: chunk, sourceUrl: meta.sourceUrl, sourceTitle: meta.title }, { timeout: 120000 });
      if(!resp.data?.parsed) { console.warn('no parsed', resp.data); continue; }
      const parsed = resp.data.parsed;
      const embedding = await embedText(chunk);

      // write nodes
      for(const node of parsed.nodes){
        const nodeId = uuidv4();
        await supabase.from('graph_nodes').insert({
          id: nodeId,
          type: node.type,
          title: node.title,
          body: node.body,
          metadata: { provenance: node.provenance, sourceUrl: meta.sourceUrl, sourceTitle: meta.title },
          keywords: node.keywords,
          vector: embedding,
          created_by: null,
          created_at: new Date().toISOString()
        });
        node.__assigned_id = nodeId;
      }

      // write edges
      for(const edge of parsed.edges){
        const src = parsed.nodes.find((n:any)=>n.id_hint === edge.source_hint);
        const tgt = parsed.nodes.find((n:any)=>n.id_hint === edge.target_hint);
        await supabase.from('graph_edges').insert({
          id: uuidv4(),
          source: src ? src.__assigned_id : null,
          target: tgt ? tgt.__assigned_id : null,
          relation: edge.relation,
          evidence: edge.evidence,
          created_by: null,
          created_at: new Date().toISOString()
        });
      }
    }

    await supabase.from('agent_jobs').update({ status:'completed', updated_at:new Date().toISOString() }).eq('id', jobId);
    return { jobId, status: 'completed' };
  } catch(err){
    console.error('ingest error', err);
    await supabase.from('agent_jobs').update({ status:'failed', output:{error:String(err)} }).eq('id', jobId);
    throw err;
  }
}

// quick-run if called directly
if(require.main === module){
  const file = process.argv[2];
  if(!file){ console.error('usage: node ingest.js <pdf>'); process.exit(1); }
  ingestPdf(file).then(console.log).catch(e=>console.error(e));
}
