// src/dedupe.ts
import { createClient } from '@supabase/supabase-js';
import dotenv from 'dotenv';
dotenv.config();

const supabase = createClient(process.env.SUPABASE_URL!, process.env.SUPABASE_SERVICE_KEY!);

// local cosine similarity (if you fetch embeddings into process)
function cosine(a: number[], b: number[]) {
  const dot = a.reduce((s, v, i) => s + v * b[i], 0);
  const magA = Math.sqrt(a.reduce((s, v) => s + v * v, 0));
  const magB = Math.sqrt(b.reduce((s, v) => s + v * v, 0));
  return dot / (magA * magB);
}

export async function findExactDuplicates() {
  const { data, error } = await supabase
    .from('artifact_index')
    .select('id, file_path, file_hash')
    .eq('file_hash', null, { count: 'exact' }); // dummy to get all -- use pagination
  // better approach: query distinct hashes and group by
  // We'll do a raw SQL aggregation
  const raw = await supabase.rpc('find_duplicate_hashes'); // See note below
  // implement server-side SQL if needed
}

// Simple fuzzy dedupe by fetching all embeddings and comparing (be careful with RAM)
export async function fuzzyDedupe(threshold = 0.88) {
  const { data, error } = await supabase.from('artifact_index').select('id,file_path,embedding');
  if (error) throw error;
  const rows = data || [];
  const seenPairs: Array<[string, string, number]> = [];
  for (let i = 0; i < rows.length; i++) {
    for (let j = i + 1; j < rows.length; j++) {
      if (!rows[i].embedding || !rows[j].embedding) continue;
      const sim = cosine(rows[i].embedding as number[], rows[j].embedding as number[]);
      if (sim >= threshold) seenPairs.push([rows[i].file_path, rows[j].file_path, sim]);
    }
  }
  return seenPairs;
}
Note: For large datasets use server-side pgvector KNN search to find nearest neighbors rather than pulling all embeddings client-side.

