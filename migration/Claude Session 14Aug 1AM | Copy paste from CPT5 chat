/**
 * Builds the extraction prompt we want the LLM to run.
 */
function buildPrompt(chunkText: string, sourceUrl?: string, sourceTitle?: string) {
  const SYSTEM = `
You are GraphRAGExtractor. For the provided CHUNK of curriculum text, extract structured curriculum graph elements.
Return strict JSON with two top-level arrays: "nodes" and "edges".
Nodes must be one of types: "nzc_outcome","unit","lesson","activity","resource","assessment".
Edges relation must be one of: "partOf","precedes","supports","uses","assesses","adaptationOf".
Include short provenance excerpts (<=25 words) and a confidence 0-1 for each item.
If uncertain about a mapping, set confidence < 0.7 and add "uncertain_reason".
Do not output any extra commentary or explanation — output EXACT JSON only.
`;

  const prompt = `
${SYSTEM}
CHUNK:
"""${chunkText.replace(/\"\"\"/g, '\\"""')}"""
METADATA:
${JSON.stringify({ sourceUrl: sourceUrl || '', sourceTitle: sourceTitle || '' })}

Instructions:
1) Identify discrete candidate nodes in the text. For each node return:
   { "id_hint": "<short-id-or-title>", "type": "...", "title": "...", "body": "...(<=200 words)",
     "yearLevels": [7,8], "subjects": ["social-studies"], "keywords": ["migration","timeline"],
     "provenance": "<25-word excerpt>", "confidence": 0.8, "uncertain_reason": "<optional>" }

2) Identify edges between nodes that are explicit or strongly implied. For each edge return:
   { "source_hint": "<id_hint>", "target_hint": "<id_hint>", "relation": "partOf",
     "evidence": "<quote or rationale <=25 words>", "confidence": 0.8 }

Return EXACT JSON: { "nodes": [...], "edges": [...] }
`;
  return prompt;
}

/**
 * Generic LLM call wrapper.
 * - If LLM_PROVIDER === 'anthropic', it posts to Anthropic's /complete endpoint (x-api-key).
 * - If 'generic', it POSTs to LLM_API_URL with { prompt, model } and Authorization Bearer.
 *
 * NOTE: adapt to your provider's required shape if needed.
 */
async function callLLM(prompt: string) {
  if (!LLM_API_KEY) throw new Error('LLM_API_KEY not configured');

  if (LLM_PROVIDER === 'anthropic') {
    // Anthropic-style call (common shape). If your Anthropic account uses a different header,
    // swap 'x-api-key' for 'Authorization: Bearer <key>' or adjust accordingly.
    const url = LLM_API_URL || 'https://api.anthropic.com/v1/complete';
    const body = {
      model: LLM_MODEL,
      prompt,
      max_tokens_to_sample: 4000,
      temperature: 0.0
    };
    const resp = await axios.post(url, body, {
      headers: { 'Content-Type': 'application/json', 'x-api-key': LLM_API_KEY }
    });
    // Anthropic returns .data.completion (or .data.output?) — different versions vary.
    // We'll try common keys then fallback to raw text.
    const data = resp.data;
    // heuristics to find the model text
    const text = data.completion ?? data.output ?? data.text ?? JSON.stringify(data);
    return String(text);
  } else {
    // Generic call: POST to LLM_API_URL with Bearer auth and body { prompt, model }
    if (!LLM_API_URL) throw new Error('LLM_API_URL must be set for generic LLM provider');
    const body = { prompt, model: LLM_MODEL };
    const resp = await axios.post(LLM_API_URL, body, {
      headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${LLM_API_KEY}` }
    });
    // try to extract text from common shapes:
    const data = resp.data;
    // OpenAI-like response handling:
    if (data.choices && Array.isArray(data.choices) && data.choices[0].message) {
      return data.choices[0].message.content;
    }
    if (data.choices && Array.isArray(data.choices) && data.choices[0].text) {
      return data.choices[0].text;
    }
    // fallback to common top-level fields
    const text = data.output ?? data.text ?? JSON.stringify(data);
    return String(text);
  }
}

/**
 * Attempt to parse JSON from an LLM text blob.
 * 1) Try JSON.parse directly.
 * 2) If fails, search for the first "{" and last "}" and parse that substring.
 * 3) If still fails, return parse error and the raw text.
 */
function tryParseJsonFromText(text: string) {
  // direct parse attempt
  try {
    const parsed = JSON.parse(text);
    return { parsed, raw: text, parseError: null };
  } catch (err) {
    // attempt to extract JSON substring
    const first = text.indexOf('{');
    const last = text.lastIndexOf('}');
    if (first !== -1 && last !== -1 && last > first) {
      const candidate = text.slice(first, last + 1);
      try {
        const parsed = JSON.parse(candidate);
        return { parsed, raw: text, parseError: null };
      } catch (err2) {
        return { parsed: null, raw: text, parseError: String(err2) };
      }
    }
    return { parsed: null, raw: text, parseError: String(err) };
  }
}

/**
 * POST /extract
 * body: { chunkText: string, sourceUrl?: string, sourceTitle?: string }
 */
app.post('/extract', async (req: Request, res: Response) => {
  try {
    const { chunkText, sourceUrl, sourceTitle } = req.body;
    if (!chunkText || typeof chunkText !== 'string') {
      return res.status(400).json({ error: 'chunkText (string) is required' });
    }

    const prompt = buildPrompt(chunkText, sourceUrl, sourceTitle);
    const modelText = await callLLM(prompt);

    const { parsed, raw, parseError } = tryParseJsonFromText(modelText);

    // If parsed is null, include helpful debugging info
    if (!parsed) {
      return res.status(500).json({
        error: 'Failed to parse LLM output as JSON',
        parseError,
        rawModelOutput: raw
      });
    }

    // Validate minimal structure
    if (!Array.isArray(parsed.nodes) || !Array.isArray(parsed.edges)) {
      return res.status(500).json({
        error: 'Parsed JSON missing required "nodes" or "edges" arrays',
        parsed
      });
    }

    // success
    return res.json({
      success: true,
      parsed,
      rawModelOutput: raw
    });
  } catch (err: any) {
    console.error('extract error', err?.message ?? err);
    return res.status(500).json({ error: String(err?.message ?? err) });
  }
});

