/** Simple chunker by roughly N characters */
function chunkText(text: string, maxChars = 3000): string[] {
  const chunks: string[] = [];
  let start = 0;
  while (start < text.length) {
    const slice = text.slice(start, start + maxChars);
    // try to cut at last paragraph/newline for nicer chunks
    const lastNL = slice.lastIndexOf('\n\n');
    const take = lastNL > 200 ? lastNL : slice.length;
    chunks.push(slice.slice(0, take));
    start += take;
  }
  return chunks;
}

