// src/extractor/server.ts
import express, { Request, Response } from 'express';
import cors from 'cors';
import axios from 'axios';
import dotenv from 'dotenv';
dotenv.config();

const PORT = Number(process.env.PORT || 3001);
const LLM_PROVIDER = (process.env.LLM_PROVIDER || 'generic').toLowerCase();
const LLM_API_KEY = process.env.LLM_API_KEY || '';
const LLM_API_URL = process.env.LLM_API_URL || ''; // provider URL
const LLM_MODEL = process.env.LLM_MODEL || 'claude-2.1';

const app = express();
app.use(cors());
app.use(express.json({ limit: '4mb' }));

function buildPrompt(chunkText: string, sourceUrl?: string, sourceTitle?: string) {
  return `
You are GraphRAGExtractor. For the provided CHUNK of curriculum text, extract structured curriculum graph elements.
Return strict JSON with two top-level arrays: "nodes" and "edges".
Nodes types: "nzc_outcome","unit","lesson","activity","resource","assessment".
Edges relations: "partOf","precedes","supports","uses","assesses","adaptationOf".
Include short provenance excerpts (<=25 words) and a confidence 0-1 for each item.
If uncertain, set confidence < 0.7 and provide "uncertain_reason".
Do not output commentary — only JSON.

CHUNK:
"""${chunkText.replace(/\"\"\"/g, '\\"""')}"""

METADATA:
${JSON.stringify({ sourceUrl: sourceUrl || '', sourceTitle: sourceTitle || '' })}

Return EXACT JSON: { "nodes": [...], "edges": [...] }.
`;
}

async function callLLM(prompt: string): Promise<string> {
  if (!LLM_API_KEY) throw new Error('LLM_API_KEY not set');

  if (LLM_PROVIDER === 'anthropic') {
    const resp = await axios.post(LLM_API_URL || 'https://api.anthropic.com/v1/complete', {
      model: LLM_MODEL,
      prompt,
      max_tokens_to_sample: 4000,
      temperature: 0.0
    }, { headers: { 'Content-Type': 'application/json', 'x-api-key': LLM_API_KEY }});
    return (resp.data.completion ?? resp.data.output ?? JSON.stringify(resp.data));
  } else {
    const resp = await axios.post(LLM_API_URL, { prompt, model: LLM_MODEL }, {
      headers: { Authorization: `Bearer ${LLM_API_KEY}`, 'Content-Type': 'application/json' }
    });
    const data = resp.data;
    if (data.choices?.[0]?.message) return data.choices[0].message.content;
    if (data.choices?.[0]?.text) return data.choices[0].text;
    return JSON.stringify(data);
  }
}

function tryParseJson(text: string) {
  try { return { parsed: JSON.parse(text), raw: text, error: null }; }
  catch (e) {
    const f = text.indexOf('{'), l = text.lastIndexOf('}');
    if (f >= 0 && l > f) {
      try { return { parsed: JSON.parse(text.slice(f, l+1)), raw: text, error: null }; }
      catch (e2) { return { parsed: null, raw: text, error: String(e2) }; }
    }
    return { parsed: null, raw: text, error: String(e) };
  }
}

app.post('/extract', async (req: Request, res: Response) => {
  try {
    const { chunkText, sourceUrl, sourceTitle } = req.body;
    if (!chunkText) return res.status(400).json({ error: 'chunkText required' });

    const prompt = buildPrompt(chunkText, sourceUrl, sourceTitle);
    const modelText = await callLLM(prompt);
    const { parsed, raw, error } = tryParseJson(modelText);

