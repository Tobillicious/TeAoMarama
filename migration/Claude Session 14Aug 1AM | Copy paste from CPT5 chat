type RouteHint = {
  task: "extract" | "critic" | "teachplan" | "explain" | "reflect";
  needReasoning?: boolean;
  maoriContent?: boolean;
  tokenEstimate?: number;
  latencyTolerance?: "low" | "med" | "high";
  costSensitivity?: "low" | "med" | "high";
};

export class AIRegistry {
  private providers: Record<string, LLM> = {};
  constructor() {
    this.providers["deepseek"] = new DeepSeek();
    // this.providers["anthropic"] = new Anthropic();
    // this.providers["openai"]    = new OpenAIClient();
  }

  get(name: string) { return this.providers[name]; }

  /**
   * Very simple policy:
   * - DeepSeek "reasoner" (e.g., deepseek-r1 / deliberate) for hard extracts/long plans
   * - DeepSeek "chat" for short/cheap tasks
   * - (If you have another provider) route Māori-critical critic tasks to your most culturally tuned model
   */
  route(hint: RouteHint) {
    const ds = this.providers["deepseek"];
    // Example rule-of-thumb routing:
    if (hint.needReasoning || (hint.tokenEstimate ?? 0) > 3000) {
      return { llm: ds, model: process.env.DEEPSEEK_REASONER_MODEL || "deepseek-reasoner" };
    }
    return { llm: ds, model: process.env.DEEPSEEK_CHAT_MODEL || "deepseek-chat" };
  }

  async generateWithRoute(prompt: string, hint: RouteHint, opts: Omit<GenOpts,"model"> = {}): Promise<GenResult> {
    const { llm, model } = this.route(hint);
    return llm.generate(prompt, { ...opts, model });
  }
}
