Create apps/teao-worker/src/replay.ts:

import { createClient } from '@supabase/supabase-js';

const supa = createClient(process.env.SUPABASE_URL!, process.env.SUPABASE_SERVICE_KEY!);

/** Simple heuristic: high salience, recent, balanced kinds */
export async function runNightlyReplay(limit = 50) {
  const { data: recent, error } = await supa
    .from('episodic_events')
    .select('*')
    .order('created_at', { ascending: false })
    .limit(500);
  if (error) throw error;

  // naive sampling for v1
  const batch = pickTopBySalience(recent, limit);
  if (batch.length < 3) return { ok: true, message: 'not enough episodes' };

  // call our consolidate endpoint
  const event_ids = batch.map(e => e.id);
  const resp = await fetch(process.env.BRAIN_URL + '/consolidate', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ event_ids, method: 'nightly_replay' })
  });
  const json = await resp.json();
  return json;
}

function pickTopBySalience(episodes:any[], limit:number) {
  return episodes
    .map(e => ({ e, score: (e.salience || 0.5) * recencyDecay(e.created_at) }))
    .sort((a,b) => b.score - a.score)
    .slice(0, limit)
    .map(x => x.e);
}
function recencyDecay(ts:string) {
  const hours = (Date.now() - new Date(ts).getTime()) / 3600000;
  return Math.exp(-hours / 72); // ~3-day half-life
}
