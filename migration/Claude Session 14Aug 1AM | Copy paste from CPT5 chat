import fs from 'fs';
import path from 'path';
import crypto from 'crypto';
import fg from 'fast-glob';
import pdfParse from 'pdf-parse';
import cheerio from 'cheerio';
import frontMatter from 'front-matter';
import { createClient } from '@supabase/supabase-js';
import axios from 'axios';
import dotenv from 'dotenv';
dotenv.config();

const SUPABASE_URL = process.env.SUPABASE_URL!;
const SUPABASE_KEY = process.env.SUPABASE_SERVICE_KEY!;
const OPENAI_API_KEY = process.env.OPENAI_API_KEY || '';
const EMBED_DIM = Number(process.env.EMBED_DIM || 1536);

const supabase = createClient(SUPABASE_URL, SUPABASE_KEY);

function sha256(buf: Buffer|string){ return crypto.createHash('sha256').update(buf).digest('hex'); }
async function extractTextFromPdf(buf: Buffer){ const d = await pdfParse(buf); return d.text || ''; }
function summarize(text: string, n=300){ if(!text) return ''; const s = text.replace(/\s+/g, ' ').trim(); return s.length<=n ? s : s.slice(0,n)+'…'; }
function extractHtml(html: string){ const $=cheerio.load(html); const title = $('title').text() || $('h1').first().text() || null; const headings: string[]=[]; $('h1,h2,h3').each((_,el)=>headings.push($(el).text())); return { title, headings, body: $('body').text() }; }

async function embedTextOpenAI(text: string){
  if(!OPENAI_API_KEY) return Array.from({length: EMBED_DIM}, ()=>Math.random());
  const resp = await axios.post('https://api.openai.com/v1/embeddings', { model:'text-embedding-3-large', input: text }, { headers: { Authorization:`Bearer ${OPENAI_API_KEY}` }});
  return resp.data.data[0].embedding;
}

async function upsertArtifact(record: any){
  const { error } = await supabase.from('artifact_index').upsert(record, { onConflict: 'file_path' });
  if(error) throw error;
}

async function processFile(filePath: string, rootDir: string){
  const ext = path.extname(filePath).toLowerCase();
  const stat = fs.statSync(filePath);
  const rel = path.relative(rootDir, filePath);
  const buf = fs.readFileSync(filePath);
  const hash = sha256(buf);
  let title = path.basename(filePath), summary='', keywords: string[] = [], metadata: any = {}, embedding = null;

  try {
    if(ext === '.pdf'){ const text = await extractTextFromPdf(buf); summary = summarize(text, 400); keywords = text.slice(0,2000).toLowerCase().match(/\b[a-zāēīōū]{4,}\b/g) || []; embedding = await embedTextOpenAI(summary); }
    else if(ext === '.md' || ext === '.markdown'){ const raw = buf.toString('utf8'); const fm = frontMatter(raw); metadata = fm.attributes || {}; title = metadata.title || title; summary = metadata.summary || summarize(String(fm.body||''), 400); keywords = metadata.tags || []; embedding = await embedTextOpenAI(summary); }
    else if(ext === '.html' || ext === '.htm'){ const out = extractHtml(buf.toString('utf8')); title = out.title || title; summary = summarize(out.body, 300); keywords = out.headings || []; embedding = await embedTextOpenAI(summary); }
    else { const txt = buf.toString('utf8'); summary = summarize(txt, 300); keywords = txt.toLowerCase().match(/\b[a-zāēīōū]{4,}\b/g) || []; embedding = await embedTextOpenAI(summary); }
  } catch(e){ console.warn('parse error', filePath, e); }

  const rec = {
    file_path: rel,
    file_name: path.basename(filePath),
    file_ext: ext,
    file_size: stat.size,
    file_hash: hash,
    artifact_type: metadata.type || null,
    title: title ? String(title).slice(0,300) : null,
    summary,
    keywords,
    agent_name: metadata.agent || null,
    metadata,
    embedding
  };
  await upsertArtifact(rec);
  console.log('indexed:', rel);
}

export async function indexFolder(rootDir: string){
  const patterns = ['**/*.md','**/*.markdown','**/*.pdf','**/*.html','**/*.htm','**/*.txt'];
  const entries = await fg(patterns, { cwd: rootDir, absolute: true, dot: true });
  console.log(`found ${entries.length} files`);
  for(const f of entries) {
    try { await processFile(f, rootDir); } catch(e){ console.error('index fail', f, e); }
  }
}

if(require.main === module){
  const dir = process.argv[2] || './te-kete-ako-clean';
  indexFolder(path.resolve(dir)).catch(e=>{ console.error(e); process.exit(1); });
}
