// src/indexer.ts
import fs from 'fs';
import path from 'path';
import crypto from 'crypto';
import fg from 'fast-glob';
import pdfParse from 'pdf-parse';
import cheerio from 'cheerio';
import frontMatter from 'front-matter';
import { createClient } from '@supabase/supabase-js';
import axios from 'axios';
import dotenv from 'dotenv';
dotenv.config();

const SUPABASE_URL = process.env.SUPABASE_URL!;
const SUPABASE_KEY = process.env.SUPABASE_SERVICE_KEY!;
const EMBEDDING_PROVIDER = process.env.EMBEDDING_PROVIDER || 'openai';
const OPENAI_API_KEY = process.env.OPENAI_API_KEY || '';
const EMBEDDING_DIM = parseInt(process.env.EMBED_DIM || '1536', 10);

if (!SUPABASE_URL || !SUPABASE_KEY) {
  console.error('Set SUPABASE_URL and SUPABASE_SERVICE_KEY in .env');
  process.exit(1);
}

const supabase = createClient(SUPABASE_URL, SUPABASE_KEY);

function sha256(content: Buffer | string) {
  return crypto.createHash('sha256').update(content).digest('hex');
}

async function extractTextFromPdf(buffer: Buffer) {
  const data = await pdfParse(buffer);
  return data.text || '';
}

function extractFromHtml(html: string) {
  const $ = cheerio.load(html);
  const title = $('title').text() || $('h1').first().text() || null;
  // get headings
  const headings: string[] = [];
  $('h1,h2,h3').each((_, el) => headings.push($(el).text()));
  // get body text
  const body = $('body').text();
  return { title, headings, body };
}

function summarizeText(text: string, maxChars = 300) {
  if (!text) return '';
  const s = text.trim().replace(/\s+/g, ' ');
  return s.length <= maxChars ? s : s.slice(0, maxChars).trim() + '…';
}

function extractKeywordsFromText(text: string, topN = 8) {
  if (!text) return [];
  const words = text
    .toLowerCase()
    .replace(/[^a-zāēīōū0-9\s]/g, ' ')
    .split(/\s+/)
    .filter(Boolean)
    .filter(w => w.length > 3);
  const freq: Record<string, number> = {};
  for (const w of words) freq[w] = (freq[w] || 0) + 1;
  const sorted = Object.entries(freq).sort((a, b) => b[1] - a[1]).slice(0, topN).map(x => x[0]);
  return sorted;
}

/** EMBEDDING: Replace with your provider call */
async function embedTextOpenAI(text: string) {
  if (!OPENAI_API_KEY) {
    // fallback: random vector (DO NOT use in prod)
    return Array.from({ length: EMBEDDING_DIM }, () => Math.random());
  }
  const resp = await axios.post(
    'https://api.openai.com/v1/embeddings',
    { model: 'text-embedding-3-large', input: text },
    { headers: { Authorization: `Bearer ${OPENAI_API_KEY}` } }
  );
  return resp.data.data[0].embedding;
}

/** decide which embedder to call */
async function embedText(text: string) {
  if (EMBEDDING_PROVIDER === 'openai') return embedTextOpenAI(text);
  // add more providers as needed
  return embedTextOpenAI(text);
}

/** Upsert artifact to Supabase */
async function upsertArtifact(record: any) {
  // Use file_path as unique key for idempotency
  const { data, error } = await supabase
    .from('artifact_index')
    .upsert(record, { onConflict: 'file_path' })
    .select()
    .limit(1);
  if (error) throw error;
  return data;
}

/** Process a single file */
async function processFile(filePath: string, rootDir: string) {
  const ext = path.extname(filePath).toLowerCase();
  const stat = fs.statSync(filePath);
  const relPath = path.relative(rootDir, filePath);
  const buffer = fs.readFileSync(filePath);
  const hash = sha256(buffer);
  let title = path.basename(filePath);
  let summary = '';
  let keywords: string[] = [];
  let metadata: any = {};
  let embedding: number[] | null = null;

  try {
    if (ext === '.pdf') {
      const text = await extractTextFromPdf(buffer);
      title = title || 'PDF';
      summary = summarizeText(text, 400);
      keywords = extractKeywordsFromText(text);
      // embed the summary for speed
      embedding = await embedText(summary.slice(0, 1000));
    } else if (ext === '.md' || ext === '.markdown') {
      const raw = buffer.toString('utf8');
      const fm = frontMatter(raw);
      metadata = fm.attributes || {};
      const body = String(fm.body || '').replace(/\r\n/g, '\n');
      title = metadata.title || (body.split('\n').find(Boolean) || title);
      summary = metadata.summary || summarizeText(body, 400);
      keywords = (metadata.tags as string[]) || extractKeywordsFromText(body);
      embedding = await embedText(summary.slice(0, 1000));
    } else if (ext === '.html' || ext === '.htm') {
      const html = buffer.toString('utf8');
      const extracted = extractFromHtml(html);
      title = extracted.title || title;
      summary = summarizeText(extracted.body, 300);
      keywords = extractKeywordsFromText(extracted.headings.join(' '));
      embedding = await embedText(summary.slice(0, 1000));
    } else {
      const text = buffer.toString('utf8');
      summary = summarizeText(text, 300);
      keywords = extractKeywordsFromText(text);
      embedding = await embedText(summary.slice(0, 1000));
    }
  } catch (err) {
    console.warn('Failed to parse file', filePath, err);
  }

  const record = {
    file_path: relPath,
    file_name: path.basename(filePath),
    file_ext: ext,
    file_size: stat.size,
    file_hash: hash,
    artifact_type: metadata.type || null,
    title: title ? String(title).slice(0, 300) : null,
    summary,
    keywords,
    agent_name: metadata.agent || null,
    metadata,
    embedding
  };

  await upsertArtifact(record);
  console.log('Indexed:', relPath);
}

/** Walk and index */
async function indexFolder(rootDir: string) {
  const patterns = ['**/*.md', '**/*.markdown', '**/*.pdf', '**/*.html', '**/*.htm', '**/*.txt'];
  const entries = await fg(patterns, { cwd: rootDir, absolute: true, dot: true });
  console.log(`Found ${entries.length} files to scan.`);
  for (const f of entries) {
    try {
      await processFile(f, rootDir);
    } catch (err) {
      console.error('Error indexing', f, err);
    }
  }
}

if (require.main === module) {
  const dir = process.argv[2] || './te-kete-ako-clean';
  indexFolder(path.resolve(dir)).catch(err => {
    console.error(err);
    process.exit(1);
  });
}
