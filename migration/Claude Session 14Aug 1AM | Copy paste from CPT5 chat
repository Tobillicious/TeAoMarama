/** Main ingestion flow: PDF -> chunks -> embedding -> extraction -> write nodes */
export async function ingestPdfFileToSupabase(filePath: string, meta: { title?: string; sourceUrl?: string } = {}) {
  const buffer = fs.readFileSync(filePath);
  const text = await extractTextFromPDF(buffer);
  const chunks = chunkText(text, 3000);

  // Create an agent_job record
  const jobId = uuidv4();
  await supabase.from('agent_jobs').insert({
    id: jobId,
    agent_name: 'ingest_service',
    job_type: 'ingest',
    input: { filePath, meta },
    status: 'running',
    created_at: new Date().toISOString()
  });

  try {
    for (const chunk of chunks) {
      // 1) extract structural nodes + edges via Claude extractor
      const extraction = await callClaudeExtractor(chunk, meta.sourceUrl);

      // 2) compute embedding for chunk or each node body
      const embedding = await embedText(chunk); // or per node

      // 3) write nodes to Supabase graph_nodes
      for (const node of extraction.nodes) {
        const nodeId = uuidv4();
        const { error } = await supabase.from('graph_nodes').insert({
          id: nodeId,
          type: node.type,
          title: node.title,
          body: node.body,
          metadata: { provenance: node.provenance, sourceUrl: meta.sourceUrl, sourceTitle: meta.title },
          keywords: node.keywords,
          vector: embedding,
          created_by: null,
          created_at: new Date().toISOString()
        });
        if (error) throw error;
        // Optionally map id_hint -> nodeId for edges
        node.__assigned_id = nodeId;
      }

      // 4) write edges (resolve hints)
      for (const edge of extraction.edges) {
        // naive resolution: find node with matching id_hint (improve later)
        const sourceNode = extraction.nodes.find(n => n.id_hint === edge.source_hint);
        const targetNode = extraction.nodes.find(n => n.id_hint === edge.target_hint);
        const { error } = await supabase.from('graph_edges').insert({
          id: uuidv4(),
          source: sourceNode ? sourceNode.__assigned_id : null,
          target: targetNode ? targetNode.__assigned_id : null,
          relation: edge.relation,
          evidence: edge.evidence,
          created_by: null,
          created_at: new Date().toISOString()
        });
        if (error) {
          // continue but log
          console.error('edge insert error', error);
        }
      }
    }

    // mark job completed
    await supabase.from('agent_jobs').update({ status: 'completed' }).eq('id', jobId);
    return { jobId, status: 'completed' };
  } catch (err) {
    console.error('ingest error', err);
    await supabase.from('agent_jobs').update({ status: 'failed', output: { error: String(err) } }).eq('id', jobId);
    throw err;
  }
}

