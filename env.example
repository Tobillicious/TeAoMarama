# TeAoMarama Educational Platform - API Configuration
# Copy this file to .env and add your actual API keys

# GLM API Configuration (Zhipu AI)
GLM_API_KEY=your_glm_api_key_here
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions

# Exa.ai Configuration for Link Validation
EXASEARCH_API_KEY=your_exa_api_key_here

# Firebase Configuration (if using production)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Development Settings
VITE_USE_FIREBASE_EMULATOR=true
VITE_DEV_MODE=true

# Performance Monitoring
VITE_ENABLE_PERFORMANCE_MONITORING=true
VITE_ENABLE_SERVICE_WORKER=true
